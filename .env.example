# MongoDB
# Get your free cluster at https://mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mlbb-counter-pro?retryWrites=true&w=majority

# Seed API Key (used by /api/seed - POST)
# Generate with: openssl rand -hex 32
SEED_API_KEY=your-seed-api-key-here

# Cron Secret (used by /api/cron/* endpoints)
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Gemini API Key (for AI-powered recommendations)
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
